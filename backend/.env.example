PORT=3001
MONGODB_URI=mongodb://localhost:27017/book-reader
# QwenVL OCR servers (required). Pages are OCR'd across them in parallel and a
# failed lane falls back to the others. Format: "id|Label|url|model" entries,
# comma- or newline-separated. Each entry carries its own model so backends can
# differ — e.g. Ollama "qwen2.5vl:7b-q8_0" vs vLLM "Qwen/Qwen2.5-VL-7B-Instruct-AWQ".
QWENVL_SERVERS=macbook|MacBook|https://ollama-macbook.kevyn.com.br|qwen2.5vl:7b-q8_0,server|Server|https://qwenvl.kevyn.com.br|Qwen/Qwen2.5-VL-7B-Instruct-AWQ
# TTS synthesis servers (required). Synthesis is load-balanced across them.
# Format: "id|Label|url" entries, comma- or newline-separated.
TTS_SERVERS=macbook|MacBook|http://127.0.0.1:8000
# SLM (line-splitting) endpoint, with a fallback used only when the primary errors.
SLM_API=https://slm.kevyn.com.br
SLM_API_FALLBACK=https://ollama-macbook.kevyn.com.br
# Whisper ASR servers used to verify each synthesized segment. Comma/newline-
# separated URLs; load-balanced by least in-flight, the rest used as fallback.
WHISPER_SERVERS=https://whisper.kevyn.com.br,https://whisper-macbook.kevyn.com.br
WHISPER_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2
# Post-synthesis verification. TTS_VERIFY=0 disables it. On a mismatch the text is
# split (on . : ; , then via the SLM) and re-rendered until it matches or
# TTS_VERIFY_MAX_DEPTH is hit. THRESHOLD is the word-similarity (0..1) to accept.
TTS_VERIFY=1
TTS_VERIFY_THRESHOLD=0.85
TTS_VERIFY_MAX_DEPTH=3
TTS_VERIFY_MIN_CHARS=8
DATA_DIR=./data
# Comma-separated IPs allowed to delete books. Leave empty to allow from anywhere.
DELETE_ALLOWED_IPS=
TTS_VOICE=pt-BR-FranciscaNeural
TTS_SPEED=1.0
TTS_LANGUAGE=en
FRONTEND_ORIGIN=http://localhost:5173
